# Flask Application Configurations
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=replace_with_a_secure_random_string_in_production

# Database Connection (MySQL via PyMySQL)
# Default XAMPP MySQL setup (host=localhost, user=root, password="", database=blood_donor_db)
DATABASE_URL=mysql+pymysql://root:@localhost/blood_donor_db

# Google Maps API Integration
# Obtain a valid key from Google Cloud Console with Maps JS API, Geolocation API, and Places API enabled
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Email Notification Configurations (SMTP Settings)
# For development, you can use a local SMTP debugging server or mailtrap.io
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@blooddonorfinder.com
